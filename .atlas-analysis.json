  "keyFeatures": [
    "Student information management with parent and class associations",
    "Teacher and staff record management",
    "Parent contact information tracking",
    "Class organization and management",
    "Gym membership tracking for physical education",
    "Salary and payroll management for staff",
    "Contact form for communication",
    "Admin authentication system"
  ],
  "publicApiSurface": [
    "AddStudent.php - Add new student records",
    "ViewStudent.php - View all student records",
    "UpdateStudent.php - Update student information",
    "DeleteStudent.php - Remove student records",
    "AddTeacher.php - Add new teacher records",
    "ViewTeacher.php - View all teacher records",
    "UpdateTeacher.php - Update teacher information",
    "DeleteTeacher.php - Remove teacher records",
    "AddParent.php - Add new parent records",
    "ViewParent.php - View all parent records",
    "UpdateParent.php - Update parent information",
    "DeleteParent.php - Remove parent records",
    "AddClass.php - Add new class records",
    "ViewClass.php - View all class records",
    "UpdateClass.php - Update class information",
    "DeleteClass.php - Remove class records",
    "AddGymMember.php - Add gym member records",
    "ViewGymMember.php - View gym member records",
    "UpdateGym.php - Update gym member information",
    "DeleteGymMember.php - Remove gym member records",
    "AddSalary.php - Add salary records",
    "ViewSalary.php - View salary records",
    "UpdateSalary.php - Update salary information",
    "DeleteSalary.php - Remove salary records",
    "Contact.php - Submit contact form messages",
    "ViewContact.php - View contact form submissions",
    "admin_login.php - Admin authentication"
  ]
}
